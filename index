<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Kriaa Services | خدمات كريعة</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700&family=Orbitron:wght@600&display=swap" rel="stylesheet">
</head>
<body>

<header>
    <h2 class="logo">Kriaa</h2>
    <nav>
        <button onclick="show('home')">الرئيسية</button>
        <button onclick="show('social')">الخدمات</button>
        <button onclick="show('thumb')">تصاميم</button>
    </nav>
</header>

<section id="home" class="page active">
    <div class="hero">
        <img src="https://cdn-icons-png.flaticon.com/512/4140/4140048.png" alt="Logo">
        <h1>🔥 كبّر حسابك بسهولة</h1>
        <p>خدمات سريعة ونتائج مضمونة 100%</p>
        <button class="btn pulse" onclick="show('social')">ابدأ الآن</button>
    </div>
</section>

<section id="social" class="page">
    <h2>📊 خدماتنا المطورة</h2>
    <div class="cards">
        
        <div class="card">
            <img src="https://cdn-icons-png.flaticon.com/512/2111/2111463.png">
            <h3>متابعين انستا</h3>
            <p class="price">10DT</p>
            <p>1000 متابع</p>
            <div class="btn-group">
                <button class="buy-btn" onclick="order('1000 Insta Followers')">شراء</button>
                <button class="desc-btn" onclick="desc('متابعين بجودة ممتازة')">وصف</button>
            </div>
        </div>

        <div class="card">
            <img src="https://cdn-icons-png.flaticon.com/512/2111/2111463.png">
            <h3>مشاهدات ريلز</h3>
            <p class="price">1DT</p>
            <p>1000 مشاهدة</p>
            <div class="btn-group">
                <button class="buy-btn" onclick="order('1000 Insta Reels Views')">شراء</button>
                <button class="desc-btn" onclick="desc('سرعة فائقة في التنفيذ')">وصف</button>
            </div>
        </div>

        <div class="card">
            <img src="https://cdn-icons-png.flaticon.com/512/1077/1077035.png">
            <h3>لايكات انستا</h3>
            <p class="price">3DT</p>
            <p>1000 لايك</p>
            <div class="btn-group">
                <button class="buy-btn" onclick="order('1000 Insta Likes')">شراء</button>
                <button class="desc-btn" onclick="desc('لايكات حقيقية وآمنة')">وصف</button>
            </div>
        </div>

        <div class="card">
            <img src="https://cdn-icons-png.flaticon.com/512/3046/3046121.png">
            <h3>متابعين تيك توك</h3>
            <p class="price">15DT</p>
            <p>1000 متابع</p>
            <div class="btn-group">
                <button class="buy-btn" onclick="order('1000 TikTok Followers')">شراء</button>
                <button class="desc-btn" onclick="desc('دعم الحساب للانتشار')">وصف</button>
            </div>
        </div>

        <div class="card">
            <img src="https://cdn-icons-png.flaticon.com/512/3046/3046121.png">
            <h3>مشاهدات تيك توك</h3>
            <p class="price">1DT</p>
            <p>1000 مشاهدة</p>
            <div class="btn-group">
                <button class="buy-btn" onclick="order('1000 TikTok Views')">شراء</button>
                <button class="desc-btn" onclick="desc('توصيل فوري للمشاهدات')">وصف</button>
            </div>
        </div>

        <div class="card">
            <img src="https://cdn-icons-png.flaticon.com/512/3046/3046121.png">
            <h3>لايكات تيك توك</h3>
            <p class="price">4DT</p>
            <p>1000 لايك</p>
            <div class="btn-group">
                <button class="buy-btn" onclick="order('1000 TikTok Likes')">شراء</button>
                <button class="desc-btn" onclick="desc('تفاعل عالي للفيديو')">وصف</button>
            </div>
        </div>

        <div class="card">
            <img src="https://cdn-icons-png.flaticon.com/512/1384/1384060.png">
            <h3>مشتركين يوتيوب</h3>
            <p class="price">20DT</p>
            <p>1000 مشترك</p>
            <div class="btn-group">
                <button class="buy-btn" onclick="order('1000 YouTube Subs')">شراء</button>
                <button class="desc-btn" onclick="desc('مشتركين دائمين للقناة')">وصف</button>
            </div>
        </div>

    </div>
</section>

<section id="thumb" class="page">
    <h2>🎨 الصور المصغرة</h2>
    <div class="card" style="margin: auto; width: 280px;">
        <img src="https://cdn-icons-png.flaticon.com/512/3502/3502688.png">
        <h3>Thumbnail</h3>
        <p class="price">15DT</p>
        <button class="buy-btn" style="width:100%" onclick="order('Thumbnail Design')">اطلب تصميمك</button>
    </div>
</section>

<div class="whatsapp-float" onclick="whatsapp()">💬</div>

<script src="script.js"></script>
</body>
</html>
